{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "Event from Data Import module",
  "type": "object",
  "properties": {
    "id": {
      "description": "Event ID",
      "type": "string"
    },
    "tenant": {
      "description": "Tenant id",
      "type": "string"
    },
    "eventType": {
      "description": "Unique Event type, human-readable String, not UUID",
      "type": "string"
    },
    "payload": {
      "description": "Marc record payload",
      "type": "string"
    },
    "eventSource": {
      "description": "Resource id",
      "$ref": "dataImportEventSource.json"
    }
  }
}
